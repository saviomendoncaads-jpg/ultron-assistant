# ─────────────────────────────────────────────
#  ULTRON ASSISTANT — Configuração (CUSTO ZERO)
# ─────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores

# ── Groq (ÚNICA chave necessária — GRÁTIS) ───
# Crie conta em: https://console.groq.com  (sem cartão)
# Após criar, vá em API Keys → Create API Key
GROQ_API_KEY=gsk_...

# Modelo LLM (llama-3.3-70b-versatile é o mais capaz no plano gratuito)
GROQ_MODEL=llama-3.3-70b-versatile

# ── TTS: Voz do Ultron (edge-tts — GRÁTIS) ──
# Vozes disponíveis em PT-BR:
#   pt-BR-AntonioNeural  ← masculina, grave (recomendada para Ultron)
#   pt-BR-FranciscaNeural ← feminina
TTS_VOICE=pt-BR-AntonioNeural
TTS_RATE=-8%       # velocidade (-10% = mais lento, 0% = normal)
TTS_PITCH=-12Hz    # tom (-20Hz = mais grave, 0Hz = normal)

# ── STT: Google Speech (GRÁTIS, sem chave) ──
STT_LANGUAGE=pt-BR
AUDIO_SAMPLE_RATE=16000
AUDIO_SILENCE_THRESHOLD=500
AUDIO_SILENCE_DURATION=1.8

# ── Playwright / Sessão do Navegador ────────
BROWSER_SESSION_PATH=.browser_session
CHROME_EXECUTABLE_PATH=

# ── Wake Word (opcional) ─────────────────────
# Deixe vazio para escuta contínua
# Ou defina ex: WAKE_WORD=ultron (só responde ao ouvir "ultron")
WAKE_WORD=
