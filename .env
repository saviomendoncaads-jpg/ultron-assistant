# ─────────────────────────────────────────────
#  JARVIS — Configuração
# ─────────────────────────────────────────────

# ── Groq (ÚNICA chave necessária — GRÁTIS) ───
GROQ_API_KEY=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
GROQ_MODEL=llama-3.3-70b-versatile

# ── TTS: Voz (edge-tts — GRÁTIS) ────────────
#   pt-BR-AntonioNeural  ← masculina, grave (JARVIS)
#   pt-BR-FranciscaNeural ← feminina
TTS_VOICE=pt-BR-AntonioNeural
TTS_RATE=-8%
TTS_PITCH=-12Hz

# ── STT: Google Speech (GRÁTIS, sem chave) ──
STT_LANGUAGE=pt-BR
AUDIO_SAMPLE_RATE=16000
AUDIO_SILENCE_THRESHOLD=500
AUDIO_SILENCE_DURATION=1.8

# ── Playwright / Navegador ───────────────────
BROWSER_SESSION_PATH=.browser_session
CHROME_EXECUTABLE_PATH=

# ── Wake Word (opcional) ─────────────────────
# Deixe vazio para escuta contínua
# Ex: WAKE_WORD=jarvis  → só responde ao ouvir "jarvis"
WAKE_WORD=

# ── Cérebro — Vault do Obsidian (RAG local) ─
# Caminho completo da pasta raiz do vault
OBSIDIAN_VAULT_PATH=C:\Users\Sávio Mendonça\Documents\Obsidian\Sávio Mendonça

# Chunks retornados por busca (5 é ideal)
BRAIN_TOP_K=5

# Score mínimo BM25 — aumente para respostas mais conservadoras
BRAIN_MIN_SCORE=0.3
